---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="BuildRightPros - Professional contractor services, websites, leads, and AI-powered calling solutions" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Rammetto+One&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-bglight font-body text-gray-800">
    <Nav />

    <main class="pt-20">
      <slot />
    </main>

    <footer class="bg-gray-900 text-white py-8 mt-16">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <p>&copy; 2024 BuildRightPros. All rights reserved.</p>
        <p class="text-gray-400 text-sm mt-2">admin@buildrightpros.com</p>
        <div class="mt-4 flex justify-center gap-6 text-sm">
          <a href="/terms-of-service" class="text-gray-400 hover:text-white transition">Terms of Service</a>
          <a href="/privacy-policy" class="text-gray-400 hover:text-white transition">Privacy Policy</a>
          <a href="/refund-policy" class="text-gray-400 hover:text-white transition">Refund Policy</a>
        </div>
      </div>
    </footer>
  </body>
</html>
