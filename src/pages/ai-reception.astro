---
import Layout from '../layouts/Layout.astro';
import AdvancedROICalculator from '../components/AdvancedROICalculator.astro';
import CallHandlingPainPoints from '../components/CallHandlingPainPoints.astro';
---
<Layout title="AI Reception Service | BuildRightPros">

  <!-- ============================================
       HERO SECTION
       ============================================ -->
  <section class="hero-section bg-gradient-to-br from-bglight to-gray-100">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">Never Miss a Customer Call Again</h1>
        <p class="hero-subtitle">AI receptionist answers 24/7, books appointments, captures leads</p>
        <div class="hero-cta-group">
          <a href="#pricing" class="btn-primary">Start Free Trial</a>
          <a href="#roi-calculator" class="btn-secondary">See Your ROI</a>
        </div>
        <div class="hero-trust">
          <span class="trust-badge">⭐⭐⭐⭐⭐</span>
          <span class="trust-text">Trusted by 50+ contractors</span>
        </div>
      </div>
      <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=600&h=400&fit=crop" alt="Professional receptionist answering customer calls" />
      </div>
    </div>

    <!-- Three Statistics Boxes -->
    <div class="hero-stats">
      <div class="stat-box">
        <div class="stat-number">47%</div>
        <div class="stat-label">Of calls go unanswered during business hours</div>
      </div>
      <div class="stat-box">
        <div class="stat-number">62%</div>
        <div class="stat-label">Of customers won't call back after voicemail</div>
      </div>
      <div class="stat-box">
        <div class="stat-number">30%</div>
        <div class="stat-label">Revenue increase when calls answered in 3 rings</div>
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURES SECTION (3 Columns)
       ============================================ -->
  <section id="features" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">How It Works</h2>
      <div class="feature-grid">

        <!-- Feature 1: 24/7 Availability -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="feature-title">24/7 Availability</h3>
          <p class="feature-description">Your AI receptionist never sleeps. Answers calls instantly, even at 3 AM when your competition is closed.</p>
          <ul class="feature-list">
            <li>Answer calls day or night</li>
            <li>No holidays or sick days</li>
            <li>Instant response time</li>
          </ul>
        </div>

        <!-- Feature 2: Lead Capture -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <h3 class="feature-title">Lead Capture</h3>
          <p class="feature-description">Every call is logged with customer details. Get instant notifications via email or text.</p>
          <ul class="feature-list">
            <li>Captures name, phone, email</li>
            <li>Records service needed</li>
            <li>Instant lead notifications</li>
          </ul>
        </div>

        <!-- Feature 3: Appointment Booking -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <h3 class="feature-title">Appointment Booking</h3>
          <p class="feature-description">AI books appointments directly to your calendar. No back-and-forth scheduling.</p>
          <ul class="feature-list">
            <li>Syncs with your calendar</li>
            <li>Sends confirmation emails</li>
            <li>Reminder notifications</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       WHO ANSWERS CALLS SECTION (Pain Points)
       ============================================ -->
  <section id="callers" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-4">Who's Answering Your Calls?</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">The truth about lost revenue and missed opportunities</p>
      <CallHandlingPainPoints />
    </div>
  </section>

  <!-- ============================================
       ROI CALCULATOR SECTION
       ============================================ -->
  <section id="roi-calculator" class="section-block bg-brand-light">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-4">Calculate Your Lost Revenue</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">See exactly how much money you're losing from missed calls</p>
      <AdvancedROICalculator />
    </div>
  </section>

  <!-- ============================================
       PRICING SECTION
       ============================================ -->
  <section id="pricing" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">Simple, Transparent Pricing</h2>

      <div class="pricing-card-wrapper">
        <div class="pricing-card">
          <div class="pricing-badge">Most Popular</div>
          <h3 class="pricing-title">AI Reception Service</h3>
          <div class="pricing-amount">
            <span class="price">$296</span>
            <span class="period">/month</span>
          </div>
          <div class="pricing-setup">
            <span class="setup-label">Setup fee:</span>
            <span class="setup-price">As little as $496 to get your business started</span>
          </div>

          <ul class="pricing-features">
            <li>✓ 24/7 AI receptionist</li>
            <li>✓ Unlimited call answering</li>
            <li>✓ Lead capture & notifications</li>
            <li>✓ Appointment booking</li>
            <li>✓ Call recordings & transcripts</li>
            <li>✓ Email & SMS alerts</li>
            <li>✓ Calendar integration</li>
          </ul>

          <div class="pricing-usage">
            <p><strong>Usage-based pricing:</strong> + usage fee based on call volume (typically $0.10-0.30 per minute of AI call time)</p>
          </div>

          <div class="pricing-trial">
            <strong>7-Day Free Trial</strong> — No credit card required
          </div>

          <a href="#signup-form" class="btn-pricing">Start Free Trial</a>
        </div>
      </div>

      <div class="pricing-guarantee">
        <p class="guarantee-text">💯 <strong>30-Day Money-Back Guarantee</strong> — If you're not completely satisfied, get a full refund.</p>
      </div>
    </div>
  </section>

  <!-- ============================================
       TESTIMONIALS SECTION
       ============================================ -->
  <section id="testimonials" class="section-block bg-brand-light">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">What Contractors Say</h2>

      <div class="testimonial-grid">

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"We were missing 30% of calls during busy season. Now we capture every single lead. Best investment we've made."</p>
          <div class="testimonial-author">
            <strong>Mike Thompson</strong>
            <span>Thompson Plumbing, Salt Lake City</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"The AI sounds so natural, customers don't even realize it's not a real person. Saves us thousands per month in lost revenue."</p>
          <div class="testimonial-author">
            <strong>Sarah Martinez</strong>
            <span>Martinez HVAC, Provo</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"Setup was easy, support was great. I get text alerts for every lead and appointments show up in my calendar automatically."</p>
          <div class="testimonial-author">
            <strong>David Chen</strong>
            <span>Chen Electrical, Ogden</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       INTEGRATIONS SECTION
       ============================================ -->
  <section id="integrations" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-4">Seamless Integrations</h2>
      <p class="text-center text-lg mb-12 text-gray-600">Works with the tools you already use</p>

      <div class="integrations-grid">
        <div class="integration-card">
          <div class="integration-logo">
            <svg class="w-20 h-20" viewBox="0 0 60 25" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M59.64 14.28h-8.06c.19 1.93 1.6 2.55 3.2 2.55 1.64 0 2.96-.37 4.05-.95v3.32a8.33 8.33 0 01-4.56 1.1c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.06 1.48zm-5.92-5.62c-1.03 0-2.17.73-2.17 2.58h4.25c0-1.85-1.07-2.58-2.08-2.58zM40.95 20.3c-1.44 0-2.32-.6-2.9-1.04l-.02 4.63-4.12.87V5.57h3.76l.08 1.02a4.7 4.7 0 013.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6zM40 8.95c-.95 0-1.54.34-1.97.81l.02 6.12c.4.44.98.78 1.95.78 1.52 0 2.54-1.65 2.54-3.87 0-2.15-1.04-3.84-2.54-3.84zM28.24 5.57h4.13v14.44h-4.13V5.57zm0-4.7L32.37 0v3.36l-4.13.88V.88zm-4.32 9.35v9.79H19.8V5.57h3.7l.12 1.22c1-1.77 3.07-1.41 3.62-1.22v3.79c-.52-.17-2.29-.43-3.32.86zm-8.55 4.72c0 2.43 2.6 1.68 3.12 1.46v3.36c-.55.3-1.54.54-2.89.54a4.15 4.15 0 01-4.27-4.24l.01-13.17 4.02-.86v3.54h3.14V9.1h-3.13v5.85zm-4.91.7c0 2.97-2.31 4.66-5.73 4.66a11.2 11.2 0 01-4.46-.93v-3.93c1.38.75 3.1 1.31 4.46 1.31.92 0 1.53-.24 1.53-1C6.26 13.77 0 14.51 0 9.95 0 7.04 2.28 5.3 5.62 5.3c1.36 0 2.72.2 4.09.75v3.88a9.23 9.23 0 00-4.1-1.06c-.86 0-1.44.25-1.44.93 0 1.85 6.29.97 6.29 5.88z" fill="#635BFF"/>
            </svg>
          </div>
          <h3 class="integration-title">Stripe Payment Processing</h3>
          <p class="integration-description">Secure payment processing with instant signup and activation. Accept payments seamlessly.</p>
          <ul class="integration-features">
            <li>Instant merchant account setup</li>
            <li>PCI-compliant security</li>
            <li>Accept all major payment methods</li>
          </ul>
        </div>

        <div class="integration-card">
          <div class="integration-logo">
            <svg class="w-20 h-20" viewBox="0 0 120 30" fill="none" xmlns="http://www.w3.org/2000/svg">
              <text x="0" y="24" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#292929">Cal.com</text>
            </svg>
          </div>
          <h3 class="integration-title">Cal.com Scheduling</h3>
          <p class="integration-description">Automated appointment booking that syncs with your calendar in real-time.</p>
          <ul class="integration-features">
            <li>Real-time calendar sync</li>
            <li>Automatic confirmation emails</li>
            <li>Smart availability management</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       DEMO VOICE SECTION
       ============================================ -->
  <section id="voice-demo" class="section-block bg-bglight">
    <div class="section-inner max-w-3xl mx-auto">
      <h2 class="section-heading text-center mb-4">Hear Your AI Receptionist in Action</h2>
      <p class="text-center text-lg mb-8 text-gray-600">Listen to how naturally our AI handles customer inquiries</p>

      <div class="voice-demo-container">
        <div class="voice-equalizer">
          <div class="equalizer-bar"></div>
          <div class="equalizer-bar"></div>
          <div class="equalizer-bar"></div>
          <div class="equalizer-bar"></div>
          <div class="equalizer-bar"></div>
        </div>

        <audio id="demo-audio" controls class="audio-player">
          <source src="/audio/ai-reception-demo.mp3" type="audio/mpeg">
          Your browser does not support the audio element.
        </audio>

        <p class="demo-description">Sample call showing how BuildRightPros AI handles customer inquiries, books appointments, and captures lead information.</p>
      </div>
    </div>
  </section>

  <!-- ============================================
       SIGNUP FORM SECTION
       ============================================ -->
  <section id="signup-form" class="section-block bg-white">
    <div class="section-inner max-w-2xl mx-auto">
      <h2 class="section-heading text-center mb-4">Start Your Free Trial Today</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">No credit card required. Setup in 24 hours.</p>

      <form id="ai-reception-signup" class="signup-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="name">Full Name *</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="business">Business Name *</label>
            <input type="text" id="business" name="business" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone *</label>
            <input type="tel" id="phone" name="phone" required />
          </div>

          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required />
          </div>
        </div>

        <div class="form-group">
          <label for="trade">Type of Business</label>
          <select id="trade" name="trade">
            <option value="">Select...</option>
            <option value="plumbing">Plumbing</option>
            <option value="hvac">HVAC</option>
            <option value="electrical">Electrical</option>
            <option value="roofing">Roofing</option>
            <option value="general">General Contractor</option>
            <option value="other">Other</option>
          </select>
        </div>

        <button type="submit" class="btn-submit">Start Free Trial →</button>

        <p class="form-disclaimer">By submitting, you agree to receive communications from BuildRightPros. No spam, unsubscribe anytime.</p>
      </form>
    </div>
  </section>

</Layout>

<style>
  /* ===== HERO SECTION ===== */
  .hero-section {
    padding: 4rem 1.5rem;
    min-height: 600px;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--dark);
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .hero-cta-group {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    background: #1e40af;
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(30, 64, 175, 0.3);
  }

  .btn-primary:hover {
    background: #1e3a8a;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(30, 64, 175, 0.4);
  }

  .btn-secondary {
    background: white;
    color: #1e40af;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    border: 2px solid #1e40af;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: #1e40af;
    color: white;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text);
  }

  .trust-badge {
    color: #FFB800;
    font-size: 1.25rem;
  }

  .hero-image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }

  /* ===== HERO STATISTICS BOXES ===== */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 3rem auto 0;
  }

  .stat-box {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 2px solid #1e40af;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .stat-box:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(30, 64, 175, 0.2);
  }

  .stat-number {
    font-size: 3rem;
    font-weight: 900;
    color: #1e40af;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .stat-label {
    font-size: 1rem;
    color: #374151;
    line-height: 1.4;
  }

  /* ===== FEATURES SECTION ===== */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 2px solid var(--border);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: #1e40af;
    box-shadow: 0 8px 24px rgba(30, 64, 175, 0.15);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #1e40af, #1e3a8a);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: white;
  }

  .feature-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--dark);
  }

  .feature-description {
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    color: var(--text);
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
  }

  .feature-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #1e40af;
    font-weight: 700;
  }

  /* ===== PRICING SECTION ===== */
  .pricing-card-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .pricing-card {
    background: white;
    border: 3px solid #1e40af;
    border-radius: 16px;
    padding: 3rem;
    max-width: 480px;
    position: relative;
    box-shadow: 0 12px 40px rgba(30, 64, 175, 0.2);
  }

  .pricing-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: #1e40af;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .pricing-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--dark);
  }

  .pricing-amount {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 4rem;
    font-weight: 900;
    color: #1e40af;
  }

  .period {
    font-size: 1.5rem;
    color: var(--text);
  }

  .pricing-setup {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .setup-label {
    color: var(--text);
    margin-right: 0.5rem;
  }

  .setup-price {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dark);
    line-height: 1.4;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }

  .pricing-features li {
    padding: 0.75rem 0;
    color: var(--dark);
    font-size: 1.125rem;
  }

  .pricing-usage {
    background: #EFF6FF;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 1rem;
    color: var(--dark);
  }

  .pricing-usage p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .pricing-trial {
    background: #FFF8F0;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--dark);
  }

  .btn-pricing {
    display: block;
    width: 100%;
    background: #1e40af;
    color: white;
    padding: 1.25rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.25rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-pricing:hover {
    background: #1e3a8a;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(30, 64, 175, 0.3);
  }

  .pricing-guarantee {
    text-align: center;
    margin-top: 3rem;
  }

  .guarantee-text {
    font-size: 1.125rem;
    color: var(--text);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .testimonial-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 2px solid var(--border);
  }

  .testimonial-stars {
    color: #FFB800;
