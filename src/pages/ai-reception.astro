---
import Base from '../layouts/Base.astro';
import AdvancedROICalculator from '../components/core/AdvancedROICalculator.astro';
import CallHandlingPainPoints from '../components/core/CallHandlingPainPoints.astro';
---
<Base title="AI Reception Service | BuildRightPros">

  <!-- ============================================
       HERO SECTION
       ============================================ -->
  <section class="hero-section bg-gradient-to-br from-brand-light to-brand-muted">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class="hero-title">Never Miss a Customer Call Again</h1>
        <p class="hero-subtitle">AI receptionist answers 24/7, books appointments, captures leads</p>
        <div class="hero-cta-group">
          <a href="#pricing" class="btn-primary">Start Free Trial</a>
          <a href="#roi-calculator" class="btn-secondary">See Your ROI</a>
        </div>
        <div class="hero-trust">
          <span class="trust-badge">⭐⭐⭐⭐⭐</span>
          <span class="trust-text">Trusted by 50+ contractors</span>
        </div>
      </div>
      <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1556745753-b2904692b3cd?w=600&h=400&fit=crop" alt="AI receptionist answering calls" />
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURES SECTION (3 Columns)
       ============================================ -->
  <section id="features" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">How It Works</h2>
      <div class="feature-grid">

        <!-- Feature 1: 24/7 Availability -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="feature-title">24/7 Availability</h3>
          <p class="feature-description">Your AI receptionist never sleeps. Answers calls instantly, even at 3 AM when your competition is closed.</p>
          <ul class="feature-list">
            <li>Answer calls day or night</li>
            <li>No holidays or sick days</li>
            <li>Instant response time</li>
          </ul>
        </div>

        <!-- Feature 2: Lead Capture -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <h3 class="feature-title">Lead Capture</h3>
          <p class="feature-description">Every call is logged with customer details. Get instant notifications via email or text.</p>
          <ul class="feature-list">
            <li>Captures name, phone, email</li>
            <li>Records service needed</li>
            <li>Instant lead notifications</li>
          </ul>
        </div>

        <!-- Feature 3: Appointment Booking -->
        <div class="feature-card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <h3 class="feature-title">Appointment Booking</h3>
          <p class="feature-description">AI books appointments directly to your calendar. No back-and-forth scheduling.</p>
          <ul class="feature-list">
            <li>Syncs with your calendar</li>
            <li>Sends confirmation emails</li>
            <li>Reminder notifications</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       WHO ANSWERS CALLS SECTION (Pain Points)
       ============================================ -->
  <section id="callers" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-4">Who's Answering Your Calls?</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">The truth about lost revenue and missed opportunities</p>
      <CallHandlingPainPoints />
    </div>
  </section>

  <!-- ============================================
       ROI CALCULATOR SECTION
       ============================================ -->
  <section id="roi-calculator" class="section-block bg-brand-light">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-4">Calculate Your Lost Revenue</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">See exactly how much money you're losing from missed calls</p>
      <AdvancedROICalculator />
    </div>
  </section>

  <!-- ============================================
       PRICING SECTION
       ============================================ -->
  <section id="pricing" class="section-block bg-white">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">Simple, Transparent Pricing</h2>

      <div class="pricing-card-wrapper">
        <div class="pricing-card">
          <div class="pricing-badge">Most Popular</div>
          <h3 class="pricing-title">AI Reception Service</h3>
          <div class="pricing-amount">
            <span class="price">$149</span>
            <span class="period">/month</span>
          </div>
          <div class="pricing-setup">
            <span class="setup-label">One-time setup:</span>
            <span class="setup-price">$99</span>
          </div>

          <ul class="pricing-features">
            <li>✓ 24/7 AI receptionist</li>
            <li>✓ Unlimited call answering</li>
            <li>✓ Lead capture & notifications</li>
            <li>✓ Appointment booking</li>
            <li>✓ Call recordings & transcripts</li>
            <li>✓ Email & SMS alerts</li>
            <li>✓ Calendar integration</li>
          </ul>

          <div class="pricing-trial">
            <strong>7-Day Free Trial</strong> — No credit card required
          </div>

          <a href="#signup-form" class="btn-pricing">Start Free Trial</a>
        </div>
      </div>

      <div class="pricing-guarantee">
        <p class="guarantee-text">💯 <strong>30-Day Money-Back Guarantee</strong> — If you're not completely satisfied, get a full refund.</p>
      </div>
    </div>
  </section>

  <!-- ============================================
       TESTIMONIALS SECTION
       ============================================ -->
  <section id="testimonials" class="section-block bg-brand-light">
    <div class="section-inner">
      <h2 class="section-heading text-center mb-12">What Contractors Say</h2>

      <div class="testimonial-grid">

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"We were missing 30% of calls during busy season. Now we capture every single lead. Best investment we've made."</p>
          <div class="testimonial-author">
            <strong>Mike Thompson</strong>
            <span>Thompson Plumbing, Salt Lake City</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"The AI sounds so natural, customers don't even realize it's not a real person. Saves us thousands per month in lost revenue."</p>
          <div class="testimonial-author">
            <strong>Sarah Martinez</strong>
            <span>Martinez HVAC, Provo</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
          <p class="testimonial-text">"Setup was easy, support was great. I get text alerts for every lead and appointments show up in my calendar automatically."</p>
          <div class="testimonial-author">
            <strong>David Chen</strong>
            <span>Chen Electrical, Ogden</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================
       SIGNUP FORM SECTION
       ============================================ -->
  <section id="signup-form" class="section-block bg-white">
    <div class="section-inner max-w-2xl mx-auto">
      <h2 class="section-heading text-center mb-4">Start Your Free Trial Today</h2>
      <p class="text-center text-lg mb-8 text-brand-dark/70">No credit card required. Setup in 24 hours.</p>

      <form id="ai-reception-signup" class="signup-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="name">Full Name *</label>
            <input type="text" id="name" name="name" required />
          </div>

          <div class="form-group">
            <label for="business">Business Name *</label>
            <input type="text" id="business" name="business" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone *</label>
            <input type="tel" id="phone" name="phone" required />
          </div>

          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required />
          </div>
        </div>

        <div class="form-group">
          <label for="trade">Type of Business</label>
          <select id="trade" name="trade">
            <option value="">Select...</option>
            <option value="plumbing">Plumbing</option>
            <option value="hvac">HVAC</option>
            <option value="electrical">Electrical</option>
            <option value="roofing">Roofing</option>
            <option value="general">General Contractor</option>
            <option value="other">Other</option>
          </select>
        </div>

        <button type="submit" class="btn-submit">Start Free Trial →</button>

        <p class="form-disclaimer">By submitting, you agree to receive communications from BuildRightPros. No spam, unsubscribe anytime.</p>
      </form>
    </div>
  </section>

</Base>

<style>
  /* ===== HERO SECTION ===== */
  .hero-section {
    padding: 4rem 1.5rem;
    min-height: 600px;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--dark);
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .hero-cta-group {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(var(--accent-rgb), 0.3);
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(var(--accent-rgb), 0.4);
  }

  .btn-secondary {
    background: white;
    color: var(--accent);
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    text-decoration: none;
    border: 2px solid var(--accent);
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: var(--accent);
    color: white;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text);
  }

  .trust-badge {
    color: #FFB800;
    font-size: 1.25rem;
  }

  .hero-image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }

  /* ===== FEATURES SECTION ===== */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 2px solid var(--border);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(var(--accent-rgb), 0.15);
    transform: translateY(-4px);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: white;
  }

  .feature-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--dark);
  }

  .feature-description {
    color: var(--text);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .feature-list {
    list-style: none;
    padding: 0;
  }

  .feature-list li {
    color: var(--text);
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
  }

  .feature-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  /* ===== PRICING SECTION ===== */
  .pricing-card-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .pricing-card {
    background: white;
    border: 3px solid var(--accent);
    border-radius: 16px;
    padding: 3rem;
    max-width: 480px;
    position: relative;
    box-shadow: 0 12px 40px rgba(var(--accent-rgb), 0.2);
  }

  .pricing-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .pricing-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--dark);
  }

  .pricing-amount {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .price {
    font-size: 4rem;
    font-weight: 900;
    color: var(--accent);
  }

  .period {
    font-size: 1.5rem;
    color: var(--text);
  }

  .pricing-setup {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }

  .setup-label {
    color: var(--text);
    margin-right: 0.5rem;
  }

  .setup-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }

  .pricing-features li {
    padding: 0.75rem 0;
    color: var(--dark);
    font-size: 1.125rem;
  }

  .pricing-trial {
    background: #FFF8F0;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--dark);
  }

  .btn-pricing {
    display: block;
    width: 100%;
    background: var(--accent);
    color: white;
    padding: 1.25rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.25rem;
    text-align: center;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-pricing:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(var(--accent-rgb), 0.3);
  }

  .pricing-guarantee {
    text-align: center;
    margin-top: 3rem;
  }

  .guarantee-text {
    font-size: 1.125rem;
    color: var(--text);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .testimonial-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    border: 2px solid var(--border);
  }

  .testimonial-stars {
    color: #FFB800;
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .testimonial-text {
    color: var(--dark);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 1.125rem;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial-author strong {
    color: var(--dark);
    font-weight: 700;
  }

  .testimonial-author span {
    color: var(--text);
    font-size: 0.875rem;
  }

  /* ===== SIGNUP FORM ===== */
  .signup-form {
    background: #F9F9F9;
    padding: 2.5rem;
    border-radius: 12px;
    border: 2px solid var(--border);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--dark);
  }

  .form-group input,
  .form-group select {
    padding: 0.75rem;
    border: 2px solid var(--border);
    border-radius: 6px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--accent);
  }

  .btn-submit {
    width: 100%;
    background: var(--accent);
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 1rem;
  }

  .btn-submit:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  .form-disclaimer {
    text-align: center;
    color: var(--text);
    font-size: 0.875rem;
  }

  /* ===== SECTION UTILITIES ===== */
  .section-block {
    padding: 5rem 1.5rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-heading {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--dark);
    margin-bottom: 2rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }

    .hero-cta-group {
      flex-direction: column;
    }

    .feature-grid,
    .testimonial-grid {
      grid-template-columns: 1fr;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      font-size: 1.875rem;
    }
  }
</style>

<script>
  // Form submission handler
  const form = document.getElementById('ai-reception-signup') as HTMLFormElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        // Send to n8n webhook
        const response = await fetch('https://n8n.systemgoat.com/webhook/ai-reception-signup', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          alert('Thank you! We\'ll contact you within 24 hours to set up your free trial.');
          form.reset();
        } else {
          throw new Error('Submission failed');
        }
      } catch (error) {
        alert('Something went wrong. Please email us at admin@buildrightpros.com or call 801-348-8255.');
      }
    });
  }
</script>
