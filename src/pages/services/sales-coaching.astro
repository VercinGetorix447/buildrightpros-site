---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sales Coaching - BuildRightPros">
  <section class="bg-gradient-to-br from-blue-50 to-gray-100 py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Sales Coaching</h1>
      <p class="text-xl text-gray-700 mb-8">Master sales techniques and grow your contracting business</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">Get Started</a>
        <a href="https://cal.com/buildrightpros.com/60-min-meeting" target="_blank" rel="noopener noreferrer" class="border-2 border-blue-600 text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-600 hover:text-white transition">Book a Demo</a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">What's Included</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">One-on-one coaching sessions</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Sales script development</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Objection handling training</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Closing techniques</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Team training programs</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Ongoing support and accountability</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-blue-600 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-blue-100 mb-8">Let's develop your sales skills</p>
      <a href="/#contact" class="inline-block bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">Contact Us Today</a>
    </div>
  </section>
</Layout>
