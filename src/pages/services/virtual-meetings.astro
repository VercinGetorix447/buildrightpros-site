---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Virtual Meetings - BuildRightPros">
  <section class="bg-gradient-to-br from-blue-50 to-gray-100 py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Virtual Meetings</h1>
      <p class="text-xl text-gray-700 mb-8">Professional split-screen meetings with whiteboard and chat collaboration</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">Get Started</a>
        <a href="https://cal.com/buildrightpros.com/60-min-meeting" target="_blank" rel="noopener noreferrer" class="border-2 border-blue-600 text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-blue-600 hover:text-white transition">Book a Demo</a>
      </div>
    </div>
  </section>

  <!-- Meeting Layout Preview -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Collaborative Meeting Experience</h2>

      <!-- Visual mockup of split screen layout -->
      <div class="bg-gray-900 rounded-xl overflow-hidden shadow-2xl mb-12">
        <div class="grid md:grid-cols-2 gap-0">
          <!-- Left: Video Meeting -->
          <div class="bg-gray-800 p-8 border-r border-gray-700">
            <div class="bg-gray-700 rounded-lg aspect-video flex items-center justify-center mb-4">
              <svg class="w-16 h-16 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
              </svg>
            </div>
            <p class="text-white text-center font-semibold">Video Meeting Space</p>
            <p class="text-gray-400 text-sm text-center mt-2">Zoom or Google Meet integration</p>
          </div>

          <!-- Right: Whiteboard + Chat -->
          <div class="bg-gray-800 p-8">
            <!-- Whiteboard -->
            <div class="bg-white rounded-lg mb-4 p-4 h-48 flex items-center justify-center border-2 border-gray-300">
              <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            </div>
            <p class="text-white text-center font-semibold mb-4">Interactive Whiteboard</p>

            <!-- Chat Window -->
            <div class="bg-gray-700 rounded-lg p-4 h-32">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                <span class="text-gray-300 text-sm">Live Chat</span>
              </div>
              <div class="space-y-2">
                <div class="bg-gray-600 rounded px-2 py-1 text-gray-300 text-xs">Message 1...</div>
                <div class="bg-gray-600 rounded px-2 py-1 text-gray-300 text-xs">Message 2...</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">What's Included</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Split-screen layout with video meeting</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Interactive whiteboard for collaboration</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Live text chat window</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Zoom and Google Meet integration</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Screen sharing and recording</p>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <p class="text-gray-700">Custom branding and layouts</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Perfect For</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center p-6 bg-blue-50 rounded-lg">
          <h3 class="font-bold text-lg mb-2">Sales Presentations</h3>
          <p class="text-gray-600 text-sm">Present proposals while sketching solutions in real-time</p>
        </div>
        <div class="text-center p-6 bg-blue-50 rounded-lg">
          <h3 class="font-bold text-lg mb-2">Training Sessions</h3>
          <p class="text-gray-600 text-sm">Teach concepts with visual aids and instant Q&A</p>
        </div>
        <div class="text-center p-6 bg-blue-50 rounded-lg">
          <h3 class="font-bold text-lg mb-2">Client Consultations</h3>
          <p class="text-gray-600 text-sm">Sketch plans and discuss projects interactively</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-blue-600 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-xl text-blue-100 mb-8">Let's set up your virtual meeting space</p>
      <a href="/#contact" class="inline-block bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">Contact Us Today</a>
    </div>
  </section>
</Layout>
