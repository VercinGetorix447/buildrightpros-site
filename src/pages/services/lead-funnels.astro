<style>
  /* Funnel Timeline Animation Styles */
  .funnel-line {
    animation: lineGrow 2s ease-out forwards;
  }

  @keyframes lineGrow {
    from {
      height: 0%;
    }
    to {
      height: 100%;
    }
  }

  .funnel-step {
    opacity: 0;
    transform: translateY(30px);
  }

  .funnel-step[data-step="1"] {
    animation: fadeInUp 0.6s ease-out 0.3s forwards;
  }

  .funnel-step[data-step="2"] {
    animation: fadeInUp 0.6s ease-out 0.6s forwards;
  }

  .funnel-step[data-step="3"] {
    animation: fadeInUp 0.6s ease-out 0.9s forwards;
  }

  .funnel-step[data-step="4"] {
    animation: fadeInUp 0.6s ease-out 1.2s forwards;
  }

  .funnel-step[data-step="5"] {
    animation: fadeInUp 0.6s ease-out 1.5s forwards;
  }

  .funnel-step[data-step="6"] {
    animation: fadeInUp 0.6s ease-out 1.8s forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .step-circle {
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(59, 130, 246, 0);
    }
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .funnel-step .flex-1:first-child {
      padding-right: 0;
      text-align: left;
    }
  }
</style>

<script>
  // Intersection Observer for scroll-triggered animations
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in-view');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -100px 0px'
    });

    document.querySelectorAll('.funnel-step').forEach(step => {
      observer.observe(step);
    });
  }
</script>
