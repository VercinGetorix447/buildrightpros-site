---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Lead Funnels That Convert - BuildRightPros">

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-600 to-blue-800 py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Lead Funnels That Convert Visitors into Paying Customers</h1>
      <p class="text-xl text-blue-100 mb-8">Stop losing 90% of your leads. Turn traffic into booked jobs with proven conversion systems.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-orange-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-orange-600 transition">Get Your Funnel Built</a>
        <a href="https://cal.com/buildrightpros.com/60-min-meeting" target="_blank" rel="noopener noreferrer" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition">See Demo</a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-lg">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">The Problem Most Contractors Face</h2>
        <p class="text-lg text-gray-700 mb-4">
          You're spending money on ads and marketing, driving traffic to a generic website... and watching <strong>90% of visitors leave without contacting you</strong>.
        </p>
        <p class="text-gray-700">
          Why? Because generic websites don't convert. They confuse visitors with too many options, weak calls-to-action, and no clear path to booking.
        </p>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">What's Included in Your Lead Funnel</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Custom Landing Pages</h3>
            <p class="text-gray-600 text-sm">Service-specific pages that speak directly to customer needs</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Multi-Step Forms</h3>
            <p class="text-gray-600 text-sm">Reduce friction with easy qualification questions</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Follow-Up Automation</h3>
            <p class="text-gray-600 text-sm">Email + SMS sequences that nurture leads automatically</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Lead Scoring & Qualification</h3>
            <p class="text-gray-600 text-sm">Automatically identify and prioritize hot leads</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">CRM Integration</h3>
            <p class="text-gray-600 text-sm">Seamlessly connect to your existing systems</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-6 bg-white rounded-lg shadow-sm">
          <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">A/B Testing & Optimization</h3>
            <p class="text-gray-600 text-sm">Continuous improvement based on real data</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Funnel Journey Visualization (KEY ANIMATED SECTION) -->
  <section class="py-20 bg-gradient-to-br from-gray-900 to-gray-800">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-4">
        How Your Lead Funnel Works
      </h2>
      <p class="text-xl text-center text-gray-300 mb-16">
        From click to booking in 6 automated steps
      </p>

      <!-- Animated Timeline -->
      <div class="relative funnel-timeline">
        <!-- Connecting animated line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 top-0 h-full w-1 bg-gradient-to-b from-blue-600 via-blue-500 to-orange-500 funnel-line"></div>

        <!-- Step 1 -->
        <div class="relative mb-16 funnel-step" data-step="1">
          <div class="flex items-center">
            <div class="flex-1 md:pr-12 md:text-right">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-blue-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">Ad Click → Custom Landing Page</h3>
                <p class="text-gray-300">Visitor clicks your ad and lands on a service-specific page designed to convert</p>
              </div>
            </div>
            <div class="flex-shrink-0 w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              1
            </div>
            <div class="flex-1 hidden md:block"></div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative mb-16 funnel-step" data-step="2">
          <div class="flex items-center">
            <div class="flex-1 hidden md:block"></div>
            <div class="flex-shrink-0 w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              2
            </div>
            <div class="flex-1 md:pl-12">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-blue-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">Lead Form → Qualification Questions</h3>
                <p class="text-gray-300">Simple multi-step form captures details and qualifies the lead automatically</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative mb-16 funnel-step" data-step="3">
          <div class="flex items-center">
            <div class="flex-1 md:pr-12 md:text-right">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-blue-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">Auto-Response → Immediate Email/SMS</h3>
                <p class="text-gray-300">Lead receives instant confirmation and next steps within seconds</p>
              </div>
            </div>
            <div class="flex-shrink-0 w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              3
            </div>
            <div class="flex-1 hidden md:block"></div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="relative mb-16 funnel-step" data-step="4">
          <div class="flex items-center">
            <div class="flex-1 hidden md:block"></div>
            <div class="flex-shrink-0 w-16 h-16 bg-blue-500 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              4
            </div>
            <div class="flex-1 md:pl-12">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-blue-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">Nurture Sequence → 5-Day Follow-Up</h3>
                <p class="text-gray-300">Automated emails and texts keep your business top-of-mind</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="relative mb-16 funnel-step" data-step="5">
          <div class="flex items-center">
            <div class="flex-1 md:pr-12 md:text-right">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-orange-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">Booking → Calendar Integration</h3>
                <p class="text-gray-300">Lead books directly into your calendar - no back-and-forth</p>
              </div>
            </div>
            <div class="flex-shrink-0 w-16 h-16 bg-orange-500 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              5
            </div>
            <div class="flex-1 hidden md:block"></div>
          </div>
        </div>

        <!-- Step 6 -->
        <div class="relative funnel-step" data-step="6">
          <div class="flex items-center">
            <div class="flex-1 hidden md:block"></div>
            <div class="flex-shrink-0 w-16 h-16 bg-orange-500 rounded-full flex items-center justify-center text-white text-2xl font-bold z-10 shadow-lg step-circle">
              ✓
            </div>
            <div class="flex-1 md:pl-12">
              <div class="bg-gray-800 p-6 rounded-lg shadow-xl border border-orange-500/30">
                <h3 class="text-2xl font-bold text-white mb-2">CRM → Lead Tracking & Scoring</h3>
                <p class="text-gray-300">All data flows into your CRM with automatic scoring and follow-up tasks</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Funnel Types Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Funnel Types We Build</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-blue-50 rounded-lg border border-blue-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Service-Specific Funnels</h3>
          <p class="text-gray-700">Dedicated funnels for HVAC repair, roof replacement, plumbing emergencies, electrical upgrades, and more</p>
        </div>
        <div class="p-6 bg-red-50 rounded-lg border border-red-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Emergency Funnels</h3>
          <p class="text-gray-700">24/7 urgent service capture with instant response and priority booking</p>
        </div>
        <div class="p-6 bg-green-50 rounded-lg border border-green-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Estimate Request Funnels</h3>
          <p class="text-gray-700">Free quote capture with automatic follow-up sequences to close the deal</p>
        </div>
        <div class="p-6 bg-orange-50 rounded-lg border border-orange-200">
          <h3 class="text-xl font-bold text-gray-900 mb-3">Seasonal Promotion Funnels</h3>
          <p class="text-gray-700">Spring tune-ups, winter prep, summer deals - timed campaigns that convert</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Why Lead Funnels Work</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex gap-4">
          <div class="flex-shrink-0">
            <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-2">Higher Conversion Rates</h3>
