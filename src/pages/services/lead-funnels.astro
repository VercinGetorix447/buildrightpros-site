            </li>
          </ul>
          <a href="/#contact" class="block w-full text-center bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">Get Started</a>
        </div>

        <!-- Pro Funnels -->
        <div class="border-2 border-blue-600 rounded-lg p-6 relative shadow-lg">
          <div class="absolute -top-3 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-semibold">Most Popular</div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Pro Funnels</h3>
          <div class="mb-4">
            <span class="text-3xl font-bold text-gray-900">$1,997</span>
