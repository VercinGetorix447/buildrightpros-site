      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Lead Funnel Pricing</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Basic Funnel -->
        <div class="border-2 border-gray-200 rounded-lg p-6 hover:border-blue-600 transition">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Basic Funnel</h3>
          <div class="mb-4">
            <span class="text-3xl font-bold text-gray-900">$997</span>
            <span class="text-gray-600"> one-time</span>
          </div>
          <div class="mb-6">
            <span class="text-xl font-semibold text-blue-600">$197</span>
            <span class="text-gray-600">/month</span>
          </div>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-gray-700">1 custom funnel</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
